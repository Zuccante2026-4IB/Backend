{
  "kind": "collectionType",
  "collectionName": "eventos",
  "info": {
    "singularName": "evento",
    "pluralName": "eventos",
    "displayName": "Evento"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "desc": {
      "type": "richtext"
    },
    "date_time": {
      "type": "json"
    },
    "luogo": {
      "type": "component",
      "repeatable": false,
      "component": "evento.luogo"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "eventi"
    },
    "target": {
      "type": "enumeration",
      "enum": [
        "tutti",
        "bambini",
        "ragazzi",
        "giovani",
        "adulti",
        "adulti_maturi",
        "senior"
      ],
      "default": "tutti",
      "required": true
    },
    "org_id": {
      "type": "integer"
    },
    "imgs": {
      "type": "component",
      "repeatable": true,
      "component": "evento.immagine"
    },
    "rank": {
      "type": "component",
      "repeatable": false,
      "component": "evento.rank"
    }
  }
}
